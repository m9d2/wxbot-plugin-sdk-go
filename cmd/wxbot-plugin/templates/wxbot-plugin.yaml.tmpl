plugin:
  manifest: manifest.json
backend:
  type: go
  main: ./process
  output: ./backend/bin/{{.ID}}-process
{{if .Frontend}}frontend:
  path: ./frontend
  build: npm install && npm run build
  dist: ./frontend/dist
{{end}}package:
  output: ./dist/{{.ID}}-{{.Version}}.wxplugin
dev:
  accounts:
    - wxid: wxid_dev
      nickName: 本地开发实例
      status: online
