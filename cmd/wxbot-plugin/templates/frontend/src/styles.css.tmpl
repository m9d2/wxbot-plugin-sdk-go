:root {
  color: #17211c;
  background: #f6f7f4;
  font-family: Inter, ui-sans-serif, system-ui, -apple-system, BlinkMacSystemFont, "Segoe UI", sans-serif;
}

* {
  box-sizing: border-box;
}

body {
  margin: 0;
  min-width: 320px;
  min-height: 100vh;
  background: #f6f7f4;
}

.page {
  min-height: 100vh;
  padding: 24px;
}

.panel {
  max-width: 720px;
}

h1 {
  margin: 0 0 10px;
  font-size: 24px;
  font-weight: 700;
}

p {
  margin: 0 0 20px;
  color: #58635d;
}

dl {
  display: grid;
  grid-template-columns: 120px 1fr;
  gap: 8px 16px;
  margin: 0;
}

dt {
  color: #6b746f;
}

dd {
  margin: 0;
  color: #17211c;
}
